# Server Config
PORT=5000

# Angel One SmartAPI Credentials
# Get these from your SmartAPI developer console: https://smartapi.angelbroking.com/
ANGEL_ONE_CLIENT_CODE=your_client_code
ANGEL_ONE_PASSWORD=your_trading_pin_or_password
ANGEL_ONE_API_KEY=your_api_key
# The 16-character alphanumeric TOTP secret shown when you first scanned the QR code to enable 2FA
ANGEL_ONE_TOTP_SECRET=your_totp_secret_key
